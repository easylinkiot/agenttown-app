{
  "expo": {
    "name": "UsChat",
    "slug": "agenttown",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agenttown",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#020817"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.biceek.agenttown",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Allow UsChat to use the microphone for voice input.",
        "NSSpeechRecognitionUsageDescription": "Allow UsChat to use speech recognition for voice input.",
        "NSCameraUsageDescription": "Allow UsChat to access the camera for scanning friend QR codes and sharing photos.",
        "NSPhotoLibraryUsageDescription": "Allow UsChat to access your photo library to share images.",
        "NSPhotoLibraryAddUsageDescription": "Allow UsChat to save images to your photo library.",
        "UIBackgroundModes": [
          "audio",
          "voip"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jason.agenttown",
      "permissions": [
        "ACCESS_NETWORK_STATE",
        "BLUETOOTH",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "CAMERA",
        "MODIFY_AUDIO_SETTINGS",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PROJECTION",
        "MICROPHONE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-notifications",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow UsChat to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow UsChat to use speech recognition for voice input.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      "expo-video",
      "@cloudflare/realtimekit-react-native",
      "@cloudflare/react-native-webrtc"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc70ea68-07e9-48d8-933e-6d7053ef6c26"
      }
    },
    "owner": "ngudeveloper"
  }
}
